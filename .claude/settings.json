{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PROJECT_DIR}\"/.claude/hooks/ensure-python-venv.sh"
          },
          {
            "type": "command",
            "command": "\"${CLAUDE_PROJECT_DIR}\"/scripts/enforce-integration-runner.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|clear",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/append_context.sh"
          }
        ]
      }
    ]
  },
  "outputStyle": "default"
}
