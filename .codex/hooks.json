{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear",
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash \"$(git rev-parse --show-toplevel)/.codex/hooks/append_context.sh\"",
            "statusMessage": "Loading repository rules"
          }
        ]
      }
    ]
  }
}
